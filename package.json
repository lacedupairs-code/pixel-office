{
  "name": "pixel-office",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone browser visualizer for OpenClaw agents",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm --prefix webview-ui run build",
    "prestart": "npm run build",
    "start": "node dist/server/index.js",
    "dev": "concurrently \"ts-node-dev --respawn --transpile-only server/index.ts\" \"npm --prefix webview-ui run dev\"",
    "install:all": "npm install && npm --prefix webview-ui install",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "json5": "^2.2.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
