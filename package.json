{
  "name": "pixel-office",
  "displayName": "Pixel Office",
  "description": "OpenClaw agents as animated pixel art characters in a virtual office",
  "version": "0.1.0",
  "publisher": "lacedupairs-code",
  "private": true,
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:pixelOffice.openPanel",
    "onCommand:pixelOffice.openLayout"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pixelOffice.openPanel",
        "title": "Open Pixel Office"
      },
      {
        "command": "pixelOffice.openLayout",
        "title": "Pixel Office: Edit Layout"
      }
    ]
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "node esbuild.js",
    "build:webview": "npm --prefix webview-ui run build",
    "watch": "concurrently \"node esbuild.js --watch\" \"npm --prefix webview-ui run dev\"",
    "lint": "tsc --noEmit -p tsconfig.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.109.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.2",
    "typescript": "^5.8.3",
    "vsce": "^2.15.0"
  }
}

